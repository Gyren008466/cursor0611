# 阿里云百炼 API Key（国内推荐，https://bailian.console.aliyun.com/）
DASHSCOPE_API_KEY=sk-your-dashscope-key

# OpenAI API Key（付费模型 GPT Image 1）
OPENAI_API_KEY=sk-your-openai-key

# OpenAI 代理地址（国内用户若直连失败，可改为中转 API 地址）
# OPENAI_BASE_URL=https://api.openai.com/v1

# 网络代理（国内访问 HuggingFace/OpenAI 等需要，按你的代理软件端口修改）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# Google Gemini API Key（免费额度，https://aistudio.google.com/apikey）
GEMINI_API_KEY=

# Hugging Face Token（可选，加速免费模型，https://huggingface.co/settings/tokens）
HF_TOKEN=

# Together AI API Key（免费额度，https://api.together.xyz/）
TOGETHER_API_KEY=

# Replicate API Token（免费试用，https://replicate.com/account/api-tokens）
REPLICATE_API_TOKEN=

# 后端服务端口（可选，默认 3001）
PORT=3001
